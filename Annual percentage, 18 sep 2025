/* 
Пользователь вводит сумму денежного вклада в рублях, а также процент годовых, которые выплачивает банк. Определить сумму денег, выплачиваемых банком вкладчику каждый месяц. 
*/ 
#include <iostream> 
int main() 
{ 
    int summ = 0; 
    std::cout << "Введите сумму денежного вклада: "; 
    std::cin >> summ; int Y = 0; 
    std::cout << "Введите годовой %: "; 
    std::cin >> Y; 
    double SY = summ / 100.0 * Y / 12;
    std::cout << SY ;
    return 0;
    
}
